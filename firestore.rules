rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
         (request.auth.token.email == "admin@magiracrm.store" && request.auth.token.email_verified == true));
    }
    
    function isApproved() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users: Private by default, Admin can see all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    // Widgets: PUBLIC READ for WordPress integration
    match /widgets/{widgetId} {
      allow read: if true; 
      allow write: if isApproved() && (isAdmin() || request.auth.uid == request.resource.data.createdBy);
    }

    // Products, Orders, Logistics, etc: Approved users only
    match /products/{id} {
      allow read: if isApproved();
      allow write: if isApproved() && isAdmin();
    }

    match /orders/{id} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /logistics/{id} {
      allow read: if isApproved();
      allow write: if isApproved() && isAdmin();
    }

    match /forms/{id} {
      allow read: if true; // Forms are public for lead capture
      allow write: if isApproved();
    }

    match /leads/{id} {
      allow read: if isApproved();
      allow write: if true; // Anyone can submit a lead
    }

    match /abandoned_carts/{id} {
      allow read: if isApproved();
      allow write: if true; // Captured from public forms
    }

    match /ads_budgets/{id} {
      allow read: if isApproved();
      allow write: if isApproved();
    }
  }
}
